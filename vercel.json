{
  "buildCommand": "node node_modules/vite/bin/vite.js build && node scripts/prerender.mjs",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "redirects": [
    {
      "source": "/boxing/",
      "destination": "/programs/boxing",
      "statusCode": 301
    },
    {
      "source": "/boxing",
      "destination": "/programs/boxing",
      "statusCode": 301
    },
    {
      "source": "/trainers/jake_henderson/",
      "destination": "/trainers/jake-henderson",
      "statusCode": 301
    },
    {
      "source": "/trainers/jake_henderson",
      "destination": "/trainers/jake-henderson",
      "statusCode": 301
    },
    {
      "source": "/trainers/guy_mosley/",
      "destination": "/trainers/guy-mosley",
      "statusCode": 301
    },
    {
      "source": "/trainers/guy_mosley",
      "destination": "/trainers/guy-mosley",
      "statusCode": 301
    },
    {
      "source": "/membership/",
      "destination": "/membership",
      "statusCode": 301
    },
    {
      "source": "/contact/",
      "destination": "/contact",
      "statusCode": 301
    },
    {
      "source": "/testimonials/",
      "destination": "/testimonials",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
